namespace enki {
  void init_logger(string level);
};

dictionary EnkiTool {
  string name;
  string description;
  string parameters_json;
};

dictionary EnkiExecutionStep {
  u64 index;
  string phase;
  string kind;
  string detail;
};

dictionary EnkiAgentRunResult {
  string output;
  sequence<EnkiExecutionStep> steps;
};

enum EnkiMemoryKind {
  "RecentMessage",
  "Summary",
  "Entity",
  "Preference",
};

dictionary EnkiMemoryEntry {
  string key;
  string content;
  EnkiMemoryKind kind;
  float relevance;
  u64 timestamp_ns;
};

dictionary EnkiMemoryModule {
  string name;
};

callback interface EnkiToolHandler {
  string execute(string tool_name, string args_json, string agent_dir, string workspace_dir, string sessions_dir);
};

callback interface EnkiMemoryHandler {
  void record(string memory_name, string session_id, string user_msg, string assistant_msg);
  sequence<EnkiMemoryEntry> recall(string memory_name, string session_id, string query, u32 max_entries);
  void flush(string memory_name, string session_id);
  void consolidate(string memory_name, string session_id);
};

callback interface EnkiLlmHandler {
  string complete(string model, string messages_json, string tools_json);
};

callback interface EnkiStepHandler {
  void on_step(EnkiExecutionStep step);
};

interface EnkiWorkflowRuntime {
  constructor(
    sequence<EnkiAgent> agents,
    sequence<string> tasks_json,
    sequence<string> workflows_json,
    string? workspace_home
  );

  [Async]
  string list_workflows_json();

  [Async]
  string list_runs_json();

  [Async]
  string inspect_json(string run_id);

  [Async]
  string start_json(string request_json);

  [Async]
  string resume_json(string run_id);

  [Async]
  string submit_intervention_json(string run_id, string intervention_id, string? response);
};

interface EnkiAgent {
  [Name=new]
  constructor(
    string name,
    string system_prompt_preamble,
    string model,
    u32 max_iterations,
    string? workspace_home
  );

  [Name=with_tools]
  constructor(
    string name,
    string system_prompt_preamble,
    string model,
    u32 max_iterations,
    string? workspace_home,
    sequence<EnkiTool> tools,
    EnkiToolHandler handler
  );

  [Name=with_memory]
  constructor(
    string name,
    string system_prompt_preamble,
    string model,
    u32 max_iterations,
    string? workspace_home,
    sequence<EnkiMemoryModule> memories,
    EnkiMemoryHandler handler
  );

  [Name=with_tools_and_memory]
  constructor(
    string name,
    string system_prompt_preamble,
    string model,
    u32 max_iterations,
    string? workspace_home,
    sequence<EnkiTool> tools,
    EnkiToolHandler tool_handler,
    sequence<EnkiMemoryModule> memories,
    EnkiMemoryHandler memory_handler
  );

  [Name=with_llm]
  constructor(
    string name,
    string system_prompt_preamble,
    string model,
    u32 max_iterations,
    string? workspace_home,
    EnkiLlmHandler llm_handler
  );

  [Name=with_tools_and_llm]
  constructor(
    string name,
    string system_prompt_preamble,
    string model,
    u32 max_iterations,
    string? workspace_home,
    sequence<EnkiTool> tools,
    EnkiToolHandler handler,
    EnkiLlmHandler llm_handler
  );

  [Name=with_memory_and_llm]
  constructor(
    string name,
    string system_prompt_preamble,
    string model,
    u32 max_iterations,
    string? workspace_home,
    sequence<EnkiMemoryModule> memories,
    EnkiMemoryHandler handler,
    EnkiLlmHandler llm_handler
  );

  [Name=with_tools_memory_and_llm]
  constructor(
    string name,
    string system_prompt_preamble,
    string model,
    u32 max_iterations,
    string? workspace_home,
    sequence<EnkiTool> tools,
    EnkiToolHandler tool_handler,
    sequence<EnkiMemoryModule> memories,
    EnkiMemoryHandler memory_handler,
    EnkiLlmHandler llm_handler
  );

  [Async]
  string run(string session_id, string user_message);

  [Async]
  EnkiAgentRunResult run_with_trace(string session_id, string user_message);

  [Async]
  EnkiAgentRunResult run_with_events(string session_id, string user_message, EnkiStepHandler handler);

  void configure_workflow(string agent_id, sequence<string> capabilities);
};
